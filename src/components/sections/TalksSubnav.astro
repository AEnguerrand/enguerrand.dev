---
interface NavItem {
  href: string;
  label: string;
}

interface Props {
  sectionLinks: NavItem[];
  showAllTalks?: boolean;
  showBackHome?: boolean;
}

const { sectionLinks, showAllTalks = true, showBackHome = true } = Astro.props;
---

<nav
  aria-label="Talks section navigation"
  class="talks-subnav sticky top-[73px] z-30 mb-8 border-b border-border/80 bg-background/90 px-0 py-3 backdrop-blur"
>
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div class="flex flex-wrap items-center gap-2">
      {sectionLinks.map((item) => (
        <a
          href={item.href}
          class="talks-subnav-link px-2 py-1.5 text-xs font-semibold uppercase text-muted-foreground hover:text-foreground"
          style="letter-spacing:0.08em"
        >
          {item.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-2 text-xs sm:text-sm">
      {showAllTalks && (
        <a
          href="/talks"
          class="rounded-md border border-border/70 bg-card/70 px-3 py-1.5 font-medium text-foreground hover:border-primary/50"
        >
          All talks
        </a>
      )}
      {showBackHome && (
        <a
          href="/"
          class="rounded-md border border-border/70 bg-card/70 px-3 py-1.5 font-medium text-foreground hover:border-primary/50"
        >
          Home
        </a>
      )}
    </div>
  </div>
</nav>
